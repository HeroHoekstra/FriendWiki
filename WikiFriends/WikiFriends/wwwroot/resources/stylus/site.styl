html, body {
  margin: 0;
  padding: 0;
  
  height: 100vh;
  
  background-color: var(--background-50);
  color: var(--text-950);
}
  
body {
  display: flex;
  flex-direction: column;
}
  
main {
  flex: 1;
}
  
footer {
  display: flex;
  flex-direction: row;
  justify-content space-between;
  
  margin: 10px;
  padding: 10px;
  height: max-content;
  
  background-color: var(--text-100);
  border-radius: 10px;
  
  div {
    flex: 1;
    
    .footer-title {
    
    }
  }
}